## Mode 1: Single Webcam (for local testing via run_webcam)
camera:
  source: webcam
  webcam_index: 0
  rtsp_url: null
  process_fps: 5
  preview: true

target:
  spg_ids: ["001", "002", "003", "004"]
  outlet_id: "outlet_test"
  camera_id: "webcam_01"

## Shared Settings
recognition:
  threshold: 0.40
  min_consecutive_hits: 2
  min_det_score: 0.60
  min_face_width_px: 70
  model_name: "buffalo_l"
  execution_providers: ["CUDAExecutionProvider", "CPUExecutionProvider"]
  det_size: [640, 640]

presence:
  grace_seconds: 3 # dev: 3, production: 20
  absent_seconds: 10 # dev: 10, production: 300 (5 min)

storage:
  data_dir: "./data"
  snapshot_enabled: true
  snapshot_retention_days: 14
  sim_output_subdir: "sim_output"
  gallery_subdir: "gallery"

## Mode 2: Multi-Camera Outlet (for run_outlet)
outlet:
  id: "outlet_mkg"
  name: "Outlet Mall Kelapa Gading"
  cameras:
    - id: "cam_01"
      rtsp_url: "${RTSP_CAM_01_URL}"
      roi: null # [x1, y1, x2, y2] normalized (0.0 - 1.0)
    - id: "cam_02"
      rtsp_url: "${RTSP_CAM_02_URL}"
      roi: null # Example: [0.20, 0.15, 0.85, 0.95]
    - id: "cam_03"
      rtsp_url: "${RTSP_CAM_03_URL}"
      roi: null
    - id: "cam_04"
      rtsp_url: "${RTSP_CAM_04_URL}"
      roi: null
  target_spg_ids: ["001", "002", "003", "004"]

## Inference Server (Centralized Mode)
inference:
  frame_skip: 1          # Skip N frames between inferences (0 = every frame, 2 = process 1 in 3)
  max_frame_height: 720  # Shared memory buffer size
  max_frame_width: 1280

## Notification
notification:
  telegram_enabled: true
  telegram_bot_token_env: "SPG_TELEGRAM_BOT_TOKEN"
  telegram_chat_id_env: "SPG_TELEGRAM_CHAT_ID"
  timeout_sec: 15
  max_retries: 3
  retry_backoff_base_sec: 2
  retry_after_default_sec: 5

## Mode 3: Simulation (dev only, overrides outlet cameras with video files)
dev:
  simulate: false
  video_files:
    - "sample_video/testing_kantor.mp4"
    - "sample_video/testing_kantor.mp4"

runtime:
  worker_idle_sleep_sec: 0.05
  main_loop_sleep_sec: 0.05
  supervisor_restart_cooldown_sec: 3.0
  supervisor_max_restarts_per_minute: 12
  auto_degrade_enabled: true
  auto_degrade_lag_high_ms: 550
  auto_degrade_lag_low_ms: 220
  auto_degrade_high_streak: 25
  auto_degrade_low_streak: 60
  auto_degrade_max_frame_skip: 3
  preview_raw_enabled: false
  preview_frame_save_interval_sec: 0.2
  preview_frame_width: 640
  preview_jpeg_quality: 75

dashboard:
  host: "0.0.0.0"
  port: 8000
  reload: true
  live_window_seconds: 10
  recent_events_limit: 50
  stream_frame_interval_sec: 0.15
  stream_error_sleep_sec: 0.5
  stream_missing_frame_sleep_sec: 0.3
